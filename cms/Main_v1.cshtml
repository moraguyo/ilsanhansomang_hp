@{
    string layoutPath = "/UserData/hansomang/Layouts/hansomang_Layout";
    string cssFile = layoutPath + "/Contents/Main_v1.css";
    string jsFile = layoutPath + "/Scripts/Main_v1.js";
    string imagePath = layoutPath + "/images";
}

<link rel="stylesheet" href="@cssFile" />

<div class="cms-content-root">

    <!-- Loading Page -->
    <div id="loading-page" class="fixed inset-0">
        <div class="loading-text-group">
            <p class="loading-vision-text">우리의 비전은</p>
            <div class="loading-cross-wrapper">
                <img src="@imagePath/be57376b9422c175219bbda068f45d27598c0057.png" alt="Cross" class="loading-cross-img" />
            </div>
            <div class="loading-desc-text">
                <span class="main-name">한소망</span><span class="sub-text">이라는</span><br />
                <span class="sub-text">이름에 담겨있다</span>
            </div>
        </div>
        <div class="loading-logo-wrapper">
            <img src="@imagePath/cd09e2d4c8a86470cac7bf9b90aa1f823a9a4832.png" alt="한소망교회" class="loading-logo-img" />
        </div>
    </div>

    <div id="main-site" class="main-site-hidden">

        <!-- 1. Hero Section -->
        <section class="hero-section">
            <div class="hero-slides">
                <div class="hero-slide active">
                    <img src="@imagePath/20f58e736b8b8f1406a5d3f23f0abf68efb25349.png" alt="Welcome" class="w-full h-full object-cover" />
                    <div class="hero-overlay"></div>
                </div>
                <div class="hero-slide">
                    <img src="https://images.unsplash.com/photo-1505427214476-47e71e07abfe?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHxjaHVyY2glMjB3b3JzaGlwJTIwY29uZ3JlZ2F0aW9ufGVufDF8fHx8MTc3Mzc1MTk4N3ww&ixlib=rb-4.1.0&q=80&w=1080" alt="Church" class="w-full h-full object-cover" />
                    <div class="hero-overlay"></div>
                </div>
            </div>

            <nav class="hero-nav">
                <div class="flex items-center">
                    <img src="@imagePath/cd09e2d4c8a86470cac7bf9b90aa1f823a9a4832.png" alt="한소망교회" class="hero-logo-img" />
                </div>
                <div class="hero-nav-desktop">
                    <a href="#" class="hero-nav-link">교회소개</a>
                    <a href="#" class="hero-nav-link">예배</a>
                    <a href="#" class="hero-nav-link">목장교회</a>
                    <a href="#" class="hero-nav-link">비전의 사다리</a>
                    <a href="#" class="hero-nav-link">다음세대·청년</a>
                    <a href="#" class="hero-nav-link">선교·섬김</a>
                </div>
                <button class="hero-menu-btn" id="mobile-menu-toggle">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
                </button>
            </nav>

            <div class="hero-mobile-menu" id="hero-mobile-menu">
                <a href="#" class="hero-nav-link">교회소개</a>
                <a href="#" class="hero-nav-link">예배</a>
                <a href="#" class="hero-nav-link">목장교회</a>
                <a href="#" class="hero-nav-link">비전의 사다리</a>
                <a href="#" class="hero-nav-link">다음세대·청년</a>
                <a href="#" class="hero-nav-link">선교·섬김</a>
            </div>

            <div class="hero-text-wrapper">
                <div class="hero-title-group active">
                    <h1 class="hero-title">한소망교회에 오신것을<br />환영합니다.</h1>
                </div>
                <div class="hero-title-group">
                    <h1 class="hero-title">예수님이 꿈꾸신<br />바로 그 교회</h1>
                </div>
            </div>

            <button class="hero-arrow prev" id="hero-prev">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
            </button>
            <button class="hero-arrow next" id="hero-next">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
            </button>

            <div class="hero-dots">
                <div class="hero-dot active"></div>
                <div class="hero-dot"></div>
            </div>
        </section>

        <!-- 2. Vision Mission Section -->
        <section class="vision-section" id="vision-trigger">
            <div class="vision-sticky">
                <img src="@imagePath/be57376b9422c175219bbda068f45d27598c0057.png" alt="" class="vision-cross-bg" id="vision-cross" />

                <div class="vision-title-wrapper">
                    <h2 class="vision-title">Hansomang<br />Mission</h2>
                </div>

                <div class="vision-text-content">
                    <div class="mission-lines" id="mission-text-container">
                        <!-- Lines will be populated by JS for character highlighting -->
                    </div>
                </div>

                <div class="vision-img-wrapper" id="vision-image">
                    <div class="vision-img-container">
                        <img src="@imagePath/5b0a8feaef4217e425516a9bf369592310de3b98.png" alt="Mission" class="w-full h-full object-cover" />
                        <div class="vision-img-overlay"></div>
                    </div>
                </div>

                <div class="vision-quick-menu">
                    <div class="quick-menu-grid">
                        <div class="quick-menu-item" data-index="0">
                            <div class="quick-menu-icon">
                                <svg width="18" height="18" viewBox="0 0 36 35" fill="none"><path d="M18.07 0L22.34 13.13H36.14L24.97 21.24L29.24 34.37L18.07 26.26L6.9 34.37L11.17 21.24L0 13.13H13.8L18.07 0Z" fill="#2D2D2D" /></svg>
                            </div>
                            <p class="quick-menu-title">새가족 안내</p>
                            <p class="quick-menu-sub">처음 오셨나요? 안내드립니다.</p>
                        </div>
                        <div class="quick-menu-item" data-index="1">
                            <div class="quick-menu-icon">
                                <svg width="18" height="18" viewBox="0 0 36 35" fill="none"><path d="M18.07 0L22.34 13.13H36.14L24.97 21.24L29.24 34.37L18.07 26.26L6.9 34.37L11.17 21.24L0 13.13H13.8L18.07 0Z" fill="#2D2D2D" /></svg>
                            </div>
                            <p class="quick-menu-title">오시는 길</p>
                            <p class="quick-menu-sub">처음 오셨나요? 안내드립니다.</p>
                        </div>
                        <div class="quick-menu-item" data-index="2">
                            <div class="quick-menu-icon">
                                <svg width="18" height="18" viewBox="0 0 36 35" fill="none"><path d="M18.07 0L22.34 13.13H36.14L24.97 21.24L29.24 34.37L18.07 26.26L6.9 34.37L11.17 21.24L0 13.13H13.8L18.07 0Z" fill="#2D2D2D" /></svg>
                            </div>
                            <p class="quick-menu-title">목장교회 소개</p>
                            <p class="quick-menu-sub">처음 오셨나요? 안내드립니다.</p>
                        </div>
                        <div class="quick-menu-item" data-index="3">
                            <div class="quick-menu-icon">
                                <svg width="18" height="18" viewBox="0 0 36 35" fill="none"><path d="M18.07 0L22.34 13.13H36.14L24.97 21.24L29.24 34.37L18.07 26.26L6.9 34.37L11.17 21.24L0 13.13H13.8L18.07 0Z" fill="#2D2D2D" /></svg>
                            </div>
                            <p class="quick-menu-title">비전의 사다리</p>
                            <p class="quick-menu-sub">처음 오셨나요? 안내드립니다.</p>
                        </div>
                        <div class="quick-menu-item" data-index="4">
                            <div class="quick-menu-icon">
                                <svg width="18" height="18" viewBox="0 0 36 35" fill="none"><path d="M18.07 0L22.34 13.13H36.14L24.97 21.24L29.24 34.37L18.07 26.26L6.9 34.37L11.17 21.24L0 13.13H13.8L18.07 0Z" fill="#2D2D2D" /></svg>
                            </div>
                            <p class="quick-menu-title">행정 안내</p>
                            <p class="quick-menu-sub">처음 오셨나요? 안내드립니다.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- 3 + 4. Message Section (Card Stack) -->
        <div class="card-stack-container">
            <div class="message-card-wrapper" id="message-stack-card">
                <section class="message-section">
                    <div class="section-container">
                        <h2 class="section-title-white animate-on-scroll">MESSAGE</h2>

                        <div class="message-main-grid animate-on-scroll delay-15">
                            <div class="message-thumb-wrapper">
                                <img src="@imagePath/4e3a2c304d66e962d04b543c5ea42cc92cd3e08e.png" alt="Sermon" class="w-full h-full object-cover" />
                            </div>
                            <div class="message-text-group">
                                <span class="worship-type">Sunday Worship</span>
                                <h3 class="sermon-title">탕자의 비유 1 : 잃은 아들의 자유</h3>
                                <div class="message-divider"></div>
                                <div class="sermon-info">
                                    <p>누가복음 15장 11절-24절</p>
                                    <p>최봉규 목사 | 2026.03.15</p>
                                </div>
                            </div>
                        </div>

                        <div class="message-bottom-divider animate-on-scroll delay-25"></div>

                        <div class="message-sub-grid">
                            <div class="message-sub-card animate-on-scroll delay-30">
                                <span class="worship-type">Wednesday Worship</span>
                                <h4 class="sermon-title">사무엘하 강해 14 : 당신의 마지막 말</h4>
                                <div class="message-thumb-wrapper">
                                    <img src="@imagePath/a643fde8dd8002ef7da30276b3f55227921ac771.png" alt="Sermon" class="w-full h-full object-cover" />
                                </div>
                                <div class="sermon-info text-center">
                                    <p>누가복음 16장 11절-24절</p>
                                    <p>최봉규 목사 | 2026.03.15</p>
                                </div>
                            </div>
                            <div class="message-sub-card animate-on-scroll delay-42">
                                <span class="worship-type">Pray Meeting</span>
                                <h4 class="sermon-title">끝까지 포기하지 않는 사랑</h4>
                                <div class="message-thumb-wrapper">
                                    <img src="@imagePath/44c8a6aebbc84727c55e2e6d7c642d14484f4ce2.png" alt="Sermon" class="w-full h-full object-cover" />
                                </div>
                                <div class="sermon-info text-center">
                                    <p>누가복음 16장 11절-24절</p>
                                    <p>최봉규 목사 | 2026.03.15</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
                <div class="message-dim-overlay" id="message-dim"></div>
            </div>

            <!-- Worship Info Section -->
            <section class="worship-info-section">
                <div class="section-container">
                    <h2 class="section-title-dark animate-on-scroll">WORSHIP INFO</h2>

                    <!-- Row 1: 장년예배 -->
                    <div class="worship-row animate-on-scroll delay-15">
                        <div class="worship-img-wrapper">
                            <img src="@imagePath/61ecdd1e6a0d4dc87cb2481a6a9304d5744a88aa.png" alt="주일예배" class="w-full h-full object-cover" />
                        </div>
                        <div class="worship-content">
                            <h3 class="worship-category-title">장년예배</h3>
                            <div class="worship-table">
                                <div class="worship-table-row">
                                    <div class="worship-table-label">주일예배</div>
                                    <div class="worship-table-divider"></div>
                                    <div class="worship-table-data">
                                        <div class="worship-time-item">
                                            <span class="worship-time-part">1부</span>
                                            <span class="worship-time-value">오전 07:30</span>
                                            <span class="worship-location">한소망채플(4층)</span>
                                        </div>
                                        <div class="worship-time-item">
                                            <span class="worship-time-part">2부</span>
                                            <span class="worship-time-value">오전 09:30</span>
                                        </div>
                                        <div class="worship-time-item">
                                            <span class="worship-time-part">3부</span>
                                            <span class="worship-time-value">오전 11:30</span>
                                        </div>
                                        <div class="worship-time-item">
                                            <span class="worship-time-part">4부(청년)</span>
                                            <span class="worship-time-value">낮 02:00</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="worship-table-row">
                                    <div class="worship-table-label">말씀사경회</div>
                                    <div class="worship-table-divider"></div>
                                    <div class="worship-table-data">
                                        <div class="worship-time-item">
                                            <span class="worship-time-value">오전 07:30</span>
                                            <span class="worship-location">한소망채플(4층)</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="worship-table-row">
                                    <div class="worship-table-label">한밤의 기도회</div>
                                    <div class="worship-table-divider"></div>
                                    <div class="worship-table-data">
                                        <div class="worship-time-item">
                                            <span class="worship-time-value">오전 07:30</span>
                                            <span class="worship-location">한소망채플(4층)</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="worship-table-row">
                                    <div class="worship-table-label">매일 기도회</div>
                                    <div class="worship-table-divider"></div>
                                    <div class="worship-table-data">
                                        <div class="worship-time-item">
                                            <span class="worship-time-value">오전 07:30</span>
                                            <span class="worship-location">한소망채플(4층)</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="worship-table-row">
                                    <div class="worship-table-label">월삭 온가족 한밤의 기도회</div>
                                    <div class="worship-table-divider"></div>
                                    <div class="worship-table-data">
                                        <div class="worship-time-item">
                                            <span class="worship-time-value">오전 07:30</span>
                                            <span class="worship-location">한소망채플(4층)</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Row 2: 다음세대 -->
                    <div class="worship-row no-border animate-on-scroll delay-30">
                        <div class="worship-content">
                            <h3 class="worship-category-title">다음세대 예배</h3>
                            <div class="tabs-container">
                                <div class="tabs-list" id="nextgen-tabs">
                                    <button class="tab-btn active" data-tab="0"><span class="tab-dot"></span>해피(영아,유아,유치)</button>
                                    <button class="tab-btn" data-tab="1"><span class="tab-dot"></span>드림(유년,초등)</button>
                                    <button class="tab-btn" data-tab="2"><span class="tab-dot"></span>영어예배,어와나</button>
                                    <button class="tab-btn" data-tab="3"><span class="tab-dot"></span>청소년(중등,고등)</button>
                                    <button class="tab-btn" data-tab="4"><span class="tab-dot"></span>소망부(어린이,소망부)</button>
                                </div>
                                <div class="worship-table" id="nextgen-table-container">
                                    <!-- Table content will be updated by JS -->
                                </div>
                            </div>
                        </div>
                        <div class="worship-img-wrapper">
                            <img src="@imagePath/f2322b4c979f55cbc1bd5e3710293e66c2bd3092.png" alt="다음세대 예배" class="w-full h-full object-cover" />
                        </div>
                    </div>
                </div>
            </section>
        </div>

        <!-- 6. Ministry Section -->
        <section class="ministry-section">
            <div class="section-container">
                <h2 class="section-title-dark animate-on-scroll">MINISTRY</h2>
                <div class="ministry-grid">
                    <div class="ministry-card m-1 animate-on-scroll">
                        <img src="https://images.unsplash.com/photo-1663162550932-f67b561e656f?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHxzbWFsbCUyMGdyb3VwJTIwYmlibGUlMjBzdHVkeXxlbnwxfHx8fDE3NzM4MzU3ODB8MA&ixlib=rb-4.1.0&q=80&w=1080" alt="목장교회" class="w-full h-full object-cover" />
                        <div class="ministry-overlay m-1">
                            <p class="ministry-en">Small Group Ministry</p>
                            <h3 class="ministry-title">목장교회</h3>
                            <p class="ministry-desc">목장교회는 가정을 중심으로 모이는 소그룹 사역으로 함께 말씀을 나누고 서로를 돌보는 영적 가족 공동체입니다.</p>
                        </div>
                    </div>
                    <div class="ministry-card m-2 animate-on-scroll">
                        <img src="https://images.unsplash.com/photo-1735761059597-c406e804d621?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHx5b3V0aCUyMG1pbmlzdHJ5JTIwcHJheWVyJTIwd29yc2hpcHxlbnwxfHx8fDE3NzM4MzU3ODF8MA&ixlib=rb-4.1.0&q=80&w=1080" alt="비전의사다리" class="w-full h-full object-cover" />
                        <div class="ministry-overlay m-2">
                            <p class="ministry-en">Vision Ladder</p>
                            <h3 class="ministry-title">비전의사다리</h3>
                            <p class="ministry-desc">비전의 사다리는 훈련과 성장을 통해 하나님의 나라를 세워가는 제자훈련 사역입니다.</p>
                        </div>
                    </div>
                    <div class="ministry-card m-3 animate-on-scroll">
                        <img src="https://images.unsplash.com/photo-1702905709201-0950a1a3190f?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHxjaGlsZHJlbiUyMHdvcnNoaXAlMjBzdW5kYXklMjBzY2hvb2x8ZW58MXx8fHwxNzczODM1Nzg3fDA&ixlib=rb-4.1.0&q=80&w=1080" alt="다음세대청년 사역" class="w-full h-full object-cover" />
                        <div class="ministry-overlay m-3">
                            <p class="ministry-en">Next Generation</p>
                            <h3 class="ministry-title">다음세대청년 사역</h3>
                            <p class="ministry-desc">다음 세대를 하나님의 사람으로 세워가는 어린이, 청소년, 청년 사역입니다.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- 7. Mission Section -->
        <div class="mission-container" id="mission-scroll-trigger">
            <div class="mission-sticky">
                <div class="mission-globe" id="mission-globe">
                    <img src="@imagePath/c2c8d4ec49410753a661426ea479b46197dec0f2.png" alt="Globe" class="w-full h-full object-contain" />
                </div>

                <div class="mission-content-layer" id="mission-content">
                    <div class="mission-header">
                        <h2 class="section-title-dark">MISSION</h2>
                        <div class="mission-tabs" id="mission-category-tabs">
                            <button class="mission-tab active" data-cat="0">국내선교</button>
                            <button class="mission-tab" data-cat="1">해외선교</button>
                            <button class="mission-tab" data-cat="2">파송선교사소식</button>
                            <button class="mission-tab" data-cat="3">중보기도</button>
                            <button class="mission-tab" data-cat="4">디아코니아</button>
                        </div>
                    </div>

                    <div class="mission-slider">
                        <!-- Cards will be positioned and transformed by JS -->
                        <div class="mission-card-list" id="mission-card-list">
                            <!-- JS will populate these -->
                        </div>

                        <button class="mission-nav-btn prev" id="mission-prev">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
                        </button>
                        <button class="mission-nav-btn next" id="mission-next">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
                        </button>
                    </div>

                    <div class="mission-dots" id="mission-dots">
                        <!-- Dots will be populated by JS -->
                    </div>
                </div>
            </div>
        </div>

        <!-- 8. Gallery Section -->
        <section class="gallery-section">
            <div class="section-container">
                <h2 class="section-title-white">GALLERY</h2>
            </div>

            <div class="gallery-track-container">
                <div class="gallery-track gallery-track-left" id="gallery-track-1">
                    <!-- Images will be populated by JS for infinite loop -->
                </div>
            </div>
